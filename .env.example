# LINE Messaging API（與 FB-Scraper 的 push 相同，需 Channel access token 與接收者 userId）
LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_ID=

# 每次擷取則數（各「來源模組」上限）
TOP_N=10

# 鉅亨網 popular API
CNYES_ENABLED=true
CNYES_CATEGORY=all

# RSS：逗號分隔多個 feed URL（經濟日報等請至官網複製 RSS 連結）
RSS_ENABLED=true
RSS_FEED_URLS=https://www.cna.com.tw/rss/afe.xml

# 排程：長駐模式是否在啟動時立即執行一次（工作排程器用 --once 時可關閉）
RUN_ON_START=false
