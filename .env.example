# LINE Messaging API（與 FB-Scraper 的 push 相同，需 Channel access token 與接收者 userId）
LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_ID=

# 每次擷取則數（各「來源模組」上限）
TOP_N=10

# 鉅亨網 popular API
CNYES_ENABLED=true
CNYES_CATEGORY=all

# RSS：每個 feed 最多幾則（與 TOP_N 無關；TOP_N 仍用於鉅亨；單一 feed 上限 50）
RSS_ITEMS_PER_FEED=5
# RSS：全部 feed 合併後最多幾則（選填）。若要「約 30 家×5 則＝最多 150 則」可設 150；未設則不截斷
RSS_MAX_TOTAL=150

# RSS：RSS_ENABLED=true 且未設定 RSS_FEED_URLS 時，會讀取 config/rss_feed_catalog.json 的 URL keys
# 若要完全自訂來源，請用逗號分隔網址（設定後會略過 catalog）：
# RSS_FEED_URLS=https://example.com/feed.xml,https://other.com/rss
# 可選：自訂 catalog 檔路徑（相對於專案根目錄或絕對路徑）
# RSS_FEEDS_FILE=config/rss_feed_catalog.json
RSS_ENABLED=true

# 排程：長駐模式是否在啟動時立即執行一次晨間序列（本機單次測試請用 main.py --morning / --digest 時可關閉）
RUN_ON_START=false

# --- 台股盤前／盤後簡報（需 FinMind 免費註冊 token；TW_BRIEFING_ENABLED=true 才會跑）---
FINMIND_TOKEN=
TW_BRIEFING_ENABLED=false
# 非交易日想本機試跑完整盤前：python main.py --morning --force（仍須 FINMIND_TOKEN 與 TW_BRIEFING_ENABLED=true）
# 盤前／盤後狀態 JSON 目錄（相對於專案根目錄）
TW_STATE_DIR=data/briefing_state
# 盤後「成交活躍」參考檔數（以 TW_MARKET_PROXY_STOCKS 清單向 FinMind 查當日成交金額後排序）
TW_TOP_TURNOVER_N=12
# 強／弱分類各取幾名（以 proxy 清單對照 TaiwanStockInfo 產業後算簡易平均報酬）
TW_TOP_SECTOR_K=3
# 每個族群要列幾檔代表股（含代號與名稱；依當日漲跌幅排序）
TW_SECTOR_LEADERS_PER_INDUSTRY=3
# 僅週一盤前列「本週事件總表」；false 則每日都列（較長）
TW_WEEKLY_BRIEFING_ONLY_MONDAY=true
# 加權指數在 FinMind TaiwanStockPrice 的 data_id（請用 TAIEX；IX0001 常無資料）
TW_INDEX_STOCK_ID=TAIEX
# 用於族群／成交參考的代號清單（逗號分隔）。聚焦市值前 10 大 + 熱門族群
# （被動元件完整、功率元件、AI 伺服器、記憶體、半導體設備、廠務無塵室、
# 散熱、低軌衛星、ABF、光通完整、面板三虎）；其他產業每族群最多 3 檔。
# 留空可改用 settings.py 內建 default。自訂請以逗號分隔。
TW_MARKET_PROXY_STOCKS=2330,2317,2454,2382,2891,2881,2412,2308,3008,2882,2327,2492,2472,8043,6173,3026,6449,3357,3090,6862,4760,6573,8261,3105,3231,2344,2408,2337,8299,3583,3131,2467,6640,6187,3563,5443,2404,6139,4766,8048,5536,6667,3017,3324,3653,3491,2313,3037,8046,3189,2368,3450,4979,4977,8086,3163,3081,2409,3481,6116,2603,2609,2615,2383,6213,6274
# 非交易日是否仍推播一行提示
TW_NON_TRADING_NOTIFY=false
# 週事件表每日最多列幾筆事件（仍用於 lookahead 區塊每日上限）
TW_WEEKLY_EVENTS_MAX_PER_DAY=5
# 滾動視窗：每天盤前都顯示「未來 N 個交易日」的事件預告（取代僅週一才有的本週列表）
TW_EVENTS_LOOKAHEAD_DAYS=5
# 預告涵蓋哪些事件 kind（逗號分隔）；可選：exdiv,shareholder_meeting,short_cover,suspended_resume
# 註：shareholder_meeting / short_cover 會以 watch list（proxy+除權息+注意+處置）過濾
TW_EVENTS_LOOKAHEAD_KINDS=exdiv,shareholder_meeting,short_cover
# 「進行中」區塊涵蓋哪些 kind；可選：disposal,book_close（book_close 同樣以 watch list 過濾）
TW_EVENTS_INPROGRESS_KINDS=disposal,book_close
# 盤後是否附「明日預告」精簡列
TW_POSTMARKET_SHOW_NEXT_DAY=true

# --- 視覺化／推送 ---
# imgbb 圖床 API Key（需至 https://api.imgbb.com 免費註冊後取得）；未填則僅存本機 HTML/PNG，LINE 會降級為文字
IMGBB_API_KEY=
# 本機儀表板輸出目錄（HTML + PNG）
TW_REPORT_DIR=data/briefing_report
# 推送模式：visual = 圖片 + Flex 卡；text = 舊版純文字摘要（fallback）
TW_PUSH_MODE=visual
# 自動偵測的「熱門族群」數量（依產業平均漲幅 + 成交量排序）
TW_HOT_THEMES_K=4
# 「熱門個股」漲幅 Top N
TW_HOT_GAINERS_N=8
# 「熱門個股」跌幅 Top N
TW_HOT_LOSERS_N=5

# --- 盤後排程／重試 ---
# FinMind TaiwanStockPrice 官方更新時間為週一至週五 17:30，但實測收盤後約 14:00～14:30 多半已有資料；
# 故預設 14:30 觸發；若仍未公布會依下方重試設定自動再試。
TW_POSTMARKET_HOUR=14
TW_POSTMARKET_MINUTE=30
# 嚴格驗日：取到的最後一筆 K 線若不是當日，視為「尚未公布」（避免送出穿著今日標題、實際是上一交易日的報告）
TW_POSTMARKET_STRICT_TODAY=true
# 當日資料未公布時的重試次數與間隔（分鐘）；預設最多 3 次、每 10 分鐘
TW_POSTMARKET_MAX_RETRIES=3
TW_POSTMARKET_RETRY_INTERVAL_MIN=10
